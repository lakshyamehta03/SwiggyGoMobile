# SwiggyGo Mobile - Environment Variables
# Expo automatically injects EXPO_PUBLIC_* vars at build time.

# Backend API URL
# For localhost testing (web/simulator): http://localhost:3000
# For device testing: use your machine's LAN IP (e.g., http://192.168.1.100:3000)
#EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_API_URL=http://192.168.1.5:3000